generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CAPTURADOR
}

enum ProjectStatus {
  DRAFT
  FINALIZED
}

enum Currency {
  COP
  USD
}

model User {
  id String @id @default(cuid())
  username String @unique
  email String @unique
  passwordHash String
  role Role @default(CAPTURADOR)
  active Boolean @default(true)
  projects Project[] @relation("OwnerProjects")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id String @id @default(cuid())
  name String
  city String
  baseCurrency Currency
  advanceCurrency Currency
  advanceAmount Decimal @db.Decimal(18,2)
  exchangeRate Decimal? @db.Decimal(18,4)
  status ProjectStatus @default(DRAFT)
  ownerId String
  owner User @relation("OwnerProjects", fields:[ownerId], references:[id])
  expenses Expense[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id String @id @default(cuid())
  projectId String
  project Project @relation(fields:[projectId], references:[id], onDelete:Cascade)
  city String
  expenseDate DateTime
  description String
  quantity Decimal @db.Decimal(12,2)
  currency Currency
  unitValue Decimal @db.Decimal(18,2)
  totalValue Decimal @db.Decimal(18,2)
  receiptPath String?
  createdAt DateTime @default(now())
}
